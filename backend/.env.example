# Database
DATABASE_URL="postgresql://user:password@localhost:5432/onchain_attendance"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Alchemy
ALCHEMY_API_KEY="your_alchemy_api_key"
ALCHEMY_WEBHOOK_SECRET="your_alchemy_webhook_secret"

# Contract
CONTRACT_ADDRESS="0x7bEf8C32157C0A40A51b9bebeb7B36f236316192"
CHAIN_ID="84532"

# Wallets (never commit actual values)
RELAY_PRIVATE_KEY="0x..."       # Wallet with RELAY_ROLE on the contract
ADMIN_SIGNER_PRIVATE_KEY="0x..." # Wallet with ADMIN_ROLE; also signs QR payloads

# Privy
PRIVY_APP_ID="your_privy_app_id"
PRIVY_APP_SECRET="your_privy_app_secret"

# QR settings
QR_TTL_MS="600000"

# Server
PORT="3001"
NODE_ENV="development"
